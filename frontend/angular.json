{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "my-warehouse": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "browser": "src/main.ts",
            "index": "src/index.html",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "src/public",
                "output": "/"
              }
            ],
            "styles": ["src/styles.css"]
          },
          "configurations": {
            "production": {
              "outputHashing": "all",
              "serviceWorker": "ngsw-config.json",
              "fileReplacements": [
                {
                  "replace": "src/app/core/environment.ts",
                  "with": "src/app/core/environment.prod.ts"
                }
              ]
            },
            "development": {}
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "my-warehouse:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "my-warehouse:build:production"
            },
            "development": {
              "buildTarget": "my-warehouse:build:development"
            }
          }
          ,
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
